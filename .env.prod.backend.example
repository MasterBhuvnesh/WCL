# Env for the backend EC2 (API). Copy to .env.prod.backend next to
# docker-compose.backend.yml. Same keys as app/api/.env; see app/api/README.md
# for the full reference.

NODE_ENV=production
DATABASE_URL=postgres://user:password@host:5432/postgres?sslmode=require
# ElastiCache endpoint; only reachable from inside the VPC.
REDIS_URL=redis://host:6379
JWT_SECRET=change-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
PARTICIPANT_PASSWORD=change-me
EXAM_ID=WCL-EXAM
EXAM_TITLE=WCL Examination
EXAM_DURATION_SECONDS=3600
EXAM_QUESTIONS_TO_SERVE=60
S3_BUCKET=wcl-images
S3_REGION=ap-south-1
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
