# Shared env for the frontend EC2 (admin panel + hall-ticket portal).
# Copy to .env.prod.frontend next to docker-compose.frontend.yml.

# Hall-ticket portal: Postgres connection (RDS), read at run time.
DATABASE_URL=postgres://user:password@host:5432/postgres?sslmode=require

# Note: the admin panel's API URL (NEXT_PUBLIC_API_BASE) is baked into the
# wcladmin image at build time by CI and cannot be set here.
