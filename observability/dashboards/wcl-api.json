{
  "uid": "wcl-api",
  "title": "WCL API",
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by route (req/s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{job=\"wclapi\"}[1m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 latency by route (s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket{job=\"wclapi\"}[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Errors (4xx / 5xx per second)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"wclapi\",status=~\"4..\"}[5m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"wclapi\",status=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "API memory (RSS)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"wclapi\"}",
          "legendFormat": "RSS"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Requests last 5m",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"wclapi\"}[5m]))",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "API request log (filter by participantId in the query)",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{container=\"wclapi\"} | json | line_format \"{{.method}} {{.path}} {{.status}} {{.durationMs}}ms {{if .participantId}}participant={{.participantId}}{{end}}{{if .adminId}}admin={{.adminId}}{{end}}\""
        }
      ]
    }
  ]
}