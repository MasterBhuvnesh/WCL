PORT=4000
DATABASE_URL=postgres://wcl:wcl@localhost:5432/wcl
REDIS_URL=redis://localhost:6379
# MUST be a long random string in production.
JWT_SECRET=dev-only-secret-change-me
# Fast-clock test mode: 60 makes a 1-hour exam last 1 minute. 1 = real time.
CLOCK_MULTIPLIER=1
LOG_LEVEL=info

# Production bootstrap (NODE_ENV=production only): on first boot against an
# empty database the API creates this admin and exam itself. In development,
# use `bun run seed` instead. ADMIN_PASSWORD must not be left at the default —
# a production instance refuses to start with it.
ADMIN_EMAIL=admin@wcl.local
ADMIN_PASSWORD=adminpass
EXAM_ID=WCL-EXAM
EXAM_TITLE=WCL Examination
EXAM_DURATION_SECONDS=3600
EXAM_QUESTIONS_TO_SERVE=60

# Common candidate password: seed and participant import use this for rows
# without an explicit secret.
PARTICIPANT_PASSWORD=wclrbu2026

# S3-compatible image storage. Floci locally (S3 API at :4566, any creds); real
# S3 later via these vars. S3_PUBLIC_URL is optional and defaults to
# ${S3_ENDPOINT}/${S3_BUCKET} when unset.
S3_ENDPOINT=http://localhost:4566
S3_BUCKET=wcl-images
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
# S3_PUBLIC_URL=
