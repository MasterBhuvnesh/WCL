{
  "name": "@wcl/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Production backend for the WCL on-center examination system (Bun, Express, PostgreSQL, Redis).",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "bun run src/seed.ts",
    "import:questions": "bun scripts/import-questions.ts",
    "import:participants": "bun scripts/import-participants.ts",
    "import:seats": "bun scripts/import-hallticket-seats.ts",
    "clean": "bun scripts/clean.ts"
  },
  "dependencies": {
    "cors": "2.8.6",
    "drizzle-orm": "^0.45.2",
    "express": "4.22.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^13.4.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "26.0.1",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "6.0.3"
  }
}
