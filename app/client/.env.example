# Base URL of the API (app/api), read by the renderer via import.meta.env.
# The VITE_ prefix makes it available to all processes (electron-vite scoping);
# renderer-only would be RENDERER_VITE_, but only the renderer reads it today.
# Defaults to http://localhost:4000 when unset (src/renderer/src/lib/config.ts).
VITE_API_BASE=http://localhost:4000
