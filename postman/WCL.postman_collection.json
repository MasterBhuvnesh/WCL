        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user001\",\n  \"password\": \"password\",\n  \"examId\": \"WCL-DEMO\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res.token || res.accessToken || (res.data && res.data.token);",
                  "if (token) { pm.environment.set(\"token\", token); }",
                  "const sessionId = res.sessionId || (res.session && res.session.id) || (res.data && res.data.sessionId);",
                  "if (sessionId) { pm.environment.set(\"sessionId\", sessionId); }"
                ]
              }
            }
          ]
        },
